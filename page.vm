                            <p>Get the latest creative production updates, new templates, and asset releases via the monthly Pulse.</p>
                        </div>
                        <a href="#" class="crh-btn-secondary">View Latest Pulse</a>
                    </div>
                </div>
            </section>

        </div>
    </main>

#else
    ## =====================================================
    ## CONTENT PAGE LAYOUT (Non-Home)
    ## =====================================================
    <div class="crh-layout">

        ## Sidebar — contextual navigation
        ## Shows only the current section, not the entire nav tree.
        ## JS inserts "On This Page" TOC above this on leaf pages.
        ##
        ## Step 1: Find which root section the current page belongs to.
        ## Walk up from $page.parent until we reach a direct child of $homePage.
        #set($currentSection = false)
        #set($rootChildren = $homePage.children)
        #if($rootChildren && $rootChildren.size() > 0)
            ## Is the page itself a root section?
            #foreach($sec in $rootChildren)
                #if($page.title == $sec.title)
                    #set($currentSection = $sec)
                #end
            #end
            ## Check parent
            #if(!$currentSection && $page.parent)
                #foreach($sec in $rootChildren)
                    #if($page.parent.title == $sec.title)
                        #set($currentSection = $sec)
                    #end
                #end
            #end
            ## Check grandparent
            #if(!$currentSection && $page.parent && $page.parent.parent)
                #foreach($sec in $rootChildren)
                    #if($page.parent.parent.title == $sec.title)
                        #set($currentSection = $sec)
                    #end
                #end
            #end
            ## Check great-grandparent
            #if(!$currentSection && $page.parent && $page.parent.parent && $page.parent.parent.parent)
                #foreach($sec in $rootChildren)
                    #if($page.parent.parent.parent.title == $sec.title)
                        #set($currentSection = $sec)
                    #end
                #end
            #end
        #end

        <aside class="crh-sidebar" id="sidebarPanel">
            <div class="crh-sidebar-inner">
                ## JS inserts TOC ("On This Page") here on leaf pages

                ## Section navigation — only show current section's pages
                #if($currentSection)
                    #set($sectionChildren = $currentSection.children)
                    #set($hasChildren = ($sectionChildren && $sectionChildren.size() > 0))

                    #if($hasChildren)
                        <nav class="crh-sidebar-nav" aria-label="Section navigation">
                            ## Section heading — links back to section root
                            <a href="$currentSection.absoluteLink" class="crh-sidebar-section-link">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                                $currentSection.title
                            </a>

                            <ul class="crh-sidebar-tree">
                                #foreach($child in $sectionChildren)
                                    #set($isChildActive = ($page.title == $child.title))
                                    #set($subChildren = $child.children)
                                    #set($hasSubChildren = ($subChildren && $subChildren.size() > 0))

                                    ## Check if current page is a grandchild of this child
                                    #set($subChildActive = false)
                                    #if($hasSubChildren)
                                        #foreach($sc in $subChildren)
                                            #if($page.title == $sc.title)
                                                #set($subChildActive = true)
                                            #end
                                        #end
                                    #end

                                    <li class="crh-sidebar-item #if($isChildActive || $subChildActive)crh-sidebar-open#end">
                                        <a href="$child.absoluteLink" class="crh-sidebar-link #if($isChildActive)crh-sidebar-active#end">$child.title</a>

                                        ## Show grandchildren only if this child is active or contains the active page
                                        #if($hasSubChildren && ($isChildActive || $subChildActive))
                                            <ul class="crh-sidebar-grandchildren">
                                                #foreach($sub in $subChildren)
                                                    <li>
                                                        <a href="$sub.absoluteLink" class="crh-sidebar-link crh-sidebar-leaf #if($page.title == $sub.title)crh-sidebar-active#end">$sub.title</a>
                                                    </li>
                                                #end
                                            </ul>
                                        #end
                                    </li>
                                #end
                            </ul>
                        </nav>
                    #end
                #end
            </div>
        </aside>

        ## Mobile Sidebar Toggle
        <button class="crh-sidebar-toggle" id="sidebarToggle" aria-label="Open navigation panel">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </button>

        ## Main Content Area
        <main id="main-content" class="crh-main">
            <article class="crh-content">

                ## Breadcrumb Navigation
                <nav class="crh-breadcrumbs" aria-label="Breadcrumb">
                    ## Build ancestor chain (up to 5 levels) — start from $page.parent to avoid self-reference
                    #set($crumbs = [])
                    #set($walker = $page.parent)
                    #if($walker)#set($void = $crumbs.add(0, $walker))#end
                    #if($walker && $walker.parent)#set($walker = $walker.parent)#set($void = $crumbs.add(0, $walker))#end
                    #if($walker && $walker.parent)#set($walker = $walker.parent)#set($void = $crumbs.add(0, $walker))#end
                    #if($walker && $walker.parent)#set($walker = $walker.parent)#set($void = $crumbs.add(0, $walker))#end
                    #if($walker && $walker.parent)#set($walker = $walker.parent)#set($void = $crumbs.add(0, $walker))#end

                    #foreach($crumb in $crumbs)
                        <a href="$crumb.absoluteLink" class="crh-breadcrumb-link">
                            #if($foreach.first)
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
                            #end
                            $crumb.title
                        </a>
                        <svg class="crh-breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                    #end
                    <span class="crh-breadcrumb-current">$page.title</span>
                </nav>

                ## Audience / status tag strip — driven by Confluence page labels
                ## Recognised labels: audience-staff, audience-partner, audience-internal,
                ##                    status-draft, status-deprecated
                #if($page.labels && $page.labels.size() > 0)
                    #set($hasTagStrip = false)
                    #foreach($label in $page.labels)
                        #set($lbl = $label.name.toLowerCase())
                        #if($lbl.startsWith("audience-") || $lbl.startsWith("status-"))
                            #set($hasTagStrip = true)
                        #end
                    #end
                    #if($hasTagStrip)
                        <ul class="crh-audience-strip" aria-label="Page audience and status">
                        #foreach($label in $page.labels)
                            #set($lbl = $label.name.toLowerCase())
                            #if($lbl == "audience-staff")
                                <li><span class="crh-audience-tag">For staff</span></li>
                            #elseif($lbl == "audience-partner")
                                <li><span class="crh-audience-tag" data-variant="partner">Partner-safe</span></li>
                            #elseif($lbl == "audience-internal")
                                <li><span class="crh-audience-tag" data-variant="internal">Internal only</span></li>
                            #elseif($lbl == "status-draft")
                                <li><span class="crh-audience-tag" data-variant="draft">Draft</span></li>
                            #elseif($lbl == "status-deprecated")
                                <li><span class="crh-audience-tag" data-variant="deprecated">Deprecated</span></li>
                            #end
                        #end
                        </ul>
                    #end
                #end

                ## Page Title
                <h1 class="crh-page-title">$page.title</h1>

                ## Article Meta
                <div class="crh-article-meta">
                    #if($page.lastModificationDate)
                        <span class="crh-article-date" data-raw-date="$page.lastModificationDate">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                            <span class="crh-article-date-text">Last updated</span>
                        </span>
                    #end
                </div>

                ## Determine section vs leaf page
                #set($pageChildren = $page.children)
                #set($isSectionPage = ($pageChildren && $pageChildren.size() > 0))

                #if($isSectionPage)
                    ## Section page: content + child page grid
                    #if($page.content && $page.content.toString().trim().length() > 0)
                        <div class="crh-content-body content-body">
                            $page.content
                        </div>
                    #end
                    <div class="crh-child-pages">
                        <h2 class="crh-child-pages-heading">Pages in this section</h2>
                        <div class="crh-child-grid">
                            #foreach($childPage in $pageChildren)
                                <a href="$childPage.absoluteLink" class="crh-child-card">
                                    <div class="crh-child-card-content">
                                        <h3 class="crh-child-card-title">$childPage.title</h3>
                                        #if($childPage.excerpt && $childPage.excerpt.toString().trim().length() > 0)
                                            <p class="crh-child-card-desc">$childPage.excerpt</p>
                                        #end
                                    </div>
                                    <span class="crh-child-card-arrow">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                                    </span>
                                </a>
                            #end
                        </div>
                    </div>
                #else
                    ## Leaf page: content + feedback
                    <div class="crh-content-body content-body">
                        #if($page.content && $page.content.toString().trim().length() > 0)
                            $page.content
                        #end
                    </div>

                    ## Page Feedback Widget
                    <div class="crh-feedback-widget" id="pageFeedback">
                        <div class="crh-feedback-question">
                            <span class="crh-feedback-label">Was this page helpful?</span>
                            <div class="crh-feedback-buttons">
                                <button class="crh-feedback-btn crh-feedback-yes" data-vote="yes" aria-label="Yes, helpful">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                                    Yes
                                </button>
                                <button class="crh-feedback-btn crh-feedback-no" data-vote="no" aria-label="No, not helpful">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3H10z"/><path d="M17 2h3a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2h-3"/></svg>
                                    No
                                </button>
                            </div>
                        </div>
                        <div class="crh-feedback-thanks" id="pfThanks" style="display:none;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span>Thank you for your feedback!</span>
                        </div>
                    </div>
                #end

                ## Previous/Next Page Navigation
                #if($page.parent && $page.parent.children && $page.parent.children.size() > 1)
                    #set($siblings = $page.parent.children)
                    #set($prevPage = false)
                    #set($nextPage = false)
                    #set($foundCurrent = false)
                    #foreach($sib in $siblings)
                        #if($foundCurrent && !$nextPage)
                            #set($nextPage = $sib)
                        #end
                        #if($page.title == $sib.title)
                            #set($foundCurrent = true)
                        #end
                        #if(!$foundCurrent)
                            #set($prevPage = $sib)
                        #end
                    #end
                    <nav class="crh-page-nav">
                        <div class="crh-nav-prev">
                            #if($prevPage)
                                <a href="$prevPage.absoluteLink" class="crh-nav-button">
                                    <span class="crh-nav-label">Previous</span>
                                    <span class="crh-nav-title">$prevPage.title</span>
                                </a>
                            #end
                        </div>
                        <div class="crh-nav-next">
                            #if($nextPage)
                                <a href="$nextPage.absoluteLink" class="crh-nav-button">
                                    <span class="crh-nav-label">Next</span>
                                    <span class="crh-nav-title">$nextPage.title</span>
                                </a>
                            #end
                        </div>
                    </nav>
                #end

            </article>
        </main>

    </div>

#end## end #if($is404) / #elseif($isHome) / #else


