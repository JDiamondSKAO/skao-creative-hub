                    #if($rootChildren && $rootChildren.size() > 0)
                        #foreach($child in $rootChildren)
                            <a href="$child.absoluteLink" class="crh-cat-card crh-animate-in">
                                ## Dynamic icon assignment based on page title keywords
                                ## Structured for 6 core sections:
                                ## 1. What's New  2. Brand Guidelines  3. Templates & Assets
                                ## 4. How To Work With Us  5. Events Support  6. Tools & Resources
                                #set($childTitleLower = $child.title.toLowerCase())
                                #if($childTitleLower.contains("what's new") || $childTitleLower.contains("update") || $childTitleLower.contains("news"))
                                    <div class="crh-cat-card-icon crh-cat-icon-new">
                                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
