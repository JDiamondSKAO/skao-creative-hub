                                        </svg>
                                    </div>
                                #elseif($childTitleLower.contains("brand"))
                                    <div class="crh-cat-card-icon crh-cat-icon-brand">
                                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <circle cx="8" cy="8" r="2.5" fill="currentColor" opacity="0.7"/>
                                            <circle cx="16" cy="8" r="2.5" fill="currentColor" opacity="0.9"/>
                                            <circle cx="8" cy="16" r="2.5" fill="currentColor" opacity="0.5"/>
                                            <circle cx="16" cy="16" r="2.5" fill="currentColor" opacity="0.6"/>
                                        </svg>
                                    </div>
                                #elseif($childTitleLower.contains("template") || $childTitleLower.contains("asset") || $childTitleLower.contains("slide") || $childTitleLower.contains("deck") || $childTitleLower.contains("photo") || $childTitleLower.contains("media"))
                                    <div class="crh-cat-card-icon crh-cat-icon-templates">
                                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <rect x="3" y="3" width="7" height="7" rx="1"/>
                                            <rect x="14" y="3" width="7" height="7" rx="1"/>
                                            <rect x="3" y="14" width="7" height="7" rx="1"/>
                                            <rect x="14" y="14" width="7" height="7" rx="1"/>
                                        </svg>
                                    </div>
                                #elseif($childTitleLower.contains("how to") || $childTitleLower.contains("work with") || $childTitleLower.contains("request"))
                                    <div class="crh-cat-card-icon crh-cat-icon-howto">
                                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <circle cx="12" cy="12" r="10"/>
                                            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                                            <line x1="12" y1="17" x2="12.01" y2="17"/>
                                        </svg>
                                    </div>
                                #elseif($childTitleLower.contains("event"))
                                    <div class="crh-cat-card-icon crh-cat-icon-events">
                                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                                            <line x1="16" y1="2" x2="16" y2="6"/>
                                            <line x1="8" y1="2" x2="8" y2="6"/>
                                            <line x1="3" y1="10" x2="21" y2="10"/>
                                        </svg>
                                    </div>
                                #elseif($childTitleLower.contains("tool") || $childTitleLower.contains("resource"))
                                    <div class="crh-cat-card-icon crh-cat-icon-tools">
                                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                                        </svg>
                                    </div>
                                #else
                                    <div class="crh-cat-card-icon crh-cat-icon-default">
                                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                            <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/>
                                            <polyline points="13 2 13 9 20 9"/>
                                        </svg>
                                    </div>
                                #end
                                <h3 class="crh-cat-card-title">$child.title</h3>
                                ## Preview of child pages for description
                                #set($sectionChildren = $child.children)
                                #if($sectionChildren && $sectionChildren.size() > 0)
                                    <p class="crh-cat-card-desc">
                                        #set($descCount = 0)
                                        #foreach($sc in $sectionChildren)
                                            #if($descCount < 3)
                                                #if($descCount > 0), #end$sc.title
                                                #set($descCount = $descCount + 1)
                                            #end
                                        #end
                                        #if($sectionChildren.size() > 3), and more#end
                                    </p>
                                    <div class="crh-cat-card-footer">
                                        <span class="crh-cat-card-count">$sectionChildren.size() resources</span>
                                        <span class="crh-cat-card-link">View →</span>
                                    </div>
                                #end
                            </a>
                        #end
                    #end
                </div>
            </section>

            ## Creative Updates Strip
            <section class="crh-newsletter-strip">
                <div class="crh-newsletter-inner">
                    <div class="crh-newsletter-content">
                        <div>
