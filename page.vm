##
## SKAO Creative Hub — Scroll Viewport Page Template
## Apache Velocity 1.6 for Confluence Data Centre 8.5.26
##
## This template defines the complete HTML structure and layout for the Creative Hub portal.
## Adapted from the Science Operations Portal theme.
## Uses crh- class prefix throughout to avoid conflicts with Confluence AUI.
##
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="robots" content="index,follow">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=5.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="generator" content="Created with Scroll Viewport - K15t">

    ## Context variables for JavaScript
    <script>
        var contextPath = '$contextPath';
        var pageId = '$page.id';
        #if($page.space && $page.space.key)
            var spaceKey = '$page.space.key';
        #else
            var spaceKey = 'CRH';
        #end
    </script>

    ## Resolve viewport root (home) page by walking up the hierarchy
    #set($homePage = $page)
    #if($homePage.parent)#set($homePage = $homePage.parent)#end
    #if($homePage.parent)#set($homePage = $homePage.parent)#end
    #if($homePage.parent)#set($homePage = $homePage.parent)#end
    #if($homePage.parent)#set($homePage = $homePage.parent)#end
    #set($homeLink = $homePage.absoluteLink)

    ## Confluence panel and resource includes
    $webPanels
    $page.resources.meta
    $page.resources.js
    $page.resources.css
    $page.resources.requireForContext('viewcontent')
    $page.resources.require('com.atlassian.confluence.plugins.confluence-inline-tasks:inline-tasks-styles')

    ## Page title and OpenGraph / Twitter meta
    <title>$page.title — SKAO Creative Hub</title>
    #if($isHome)
    <meta name="description" content="The central hub for SKAO creative production — templates, brand guidelines, assets, slide decks, and creative resources.">
    #else
    <meta name="description" content="$page.title — SKAO Creative Hub resource page.">
    #end
    <meta property="og:title" content="$page.title — SKAO Creative Hub" />
    #if($isHome)
    <meta property="og:description" content="The central hub for SKAO creative production — templates, brand guidelines, assets, slide decks, and creative resources." />
    #else
    <meta property="og:description" content="$page.title — find this resource on the SKAO Creative Hub." />
    #end
    <meta property="og:image" content="${theme.baseUrl}/images/og-image.jpg" />
    <meta property="og:url" content="$page.absoluteLink" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SKAO Creative Hub" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="$page.title — SKAO Creative Hub" />
    <meta name="twitter:image" content="${theme.baseUrl}/images/og-image.jpg" />
    <link rel="canonical" href="$page.absoluteLink" />

    ## Font preconnect
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    ## Theme stylesheets
    <link rel="stylesheet" href="${theme.baseUrl}/css/style.css">
    <link rel="stylesheet" href="${theme.baseUrl}/css/eggs.css">

    ## Matter.js for interactive 404 page — only load when needed
    #set($checkTitle = $page.title.toLowerCase().trim())
    #if($checkTitle == "not found" || $checkTitle == "page not found" || $checkTitle == "404")
    <script src="https://cdnjs.cloudflare.com/ajax/libs/matter-js/0.19.0/matter.min.js" defer></script>
    #end

    ## Prevent flash of unstyled content (FOUC) — theme detection
    <script>
        (function(){
            try {
                var stored = localStorage.getItem('crh-theme');
                if (stored === 'dark') {
                    document.documentElement.classList.add('dark');
                } else if (!stored && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    document.documentElement.classList.add('dark');
                }
            } catch(e) {}
        })();
    </script>
</head>

## =====================================================
## BODY — Detect Home Page
## =====================================================
#set($isHome = ($page.title == $homePage.title))
<body#if($isHome) class="crh-home"#end>

## =====================================================
## SKIP TO CONTENT — WCAG COMPLIANCE
## =====================================================
<a href="#main-content" class="skip-to-content">Skip to main content</a>
<div class="crh-progress-bar" id="crhProgressBar" role="progressbar" aria-hidden="true"></div>

## =====================================================
## SEARCH MODAL OVERLAY
## =====================================================
<div class="crh-search-modal" id="searchModal" role="dialog" aria-modal="true" aria-labelledby="searchModalTitle" style="display:none;">
    <div class="crh-search-modal-backdrop" id="searchBackdrop"></div>
    <div class="crh-search-modal-dialog">
        <div class="crh-search-modal-header">
            <h2 id="searchModalTitle" class="crh-search-modal-title">Search the Creative Hub</h2>
            <button class="crh-search-modal-close" id="closeSearchModal" aria-label="Close search">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <form class="crh-search-form" id="searchForm" role="search">
            <div class="crh-search-input-wrapper">
                <svg class="crh-search-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input
                    type="text"
                    id="searchInput"
                    class="crh-search-input"
                    placeholder="Search templates, guidelines, brand assets..."
                    autocomplete="off"
                    aria-label="Search the Creative Hub">
            </div>
        </form>
        <div class="crh-search-results" id="searchResults">
            <div class="crh-search-empty">
                <p>Start typing to search</p>
            </div>
        </div>
        <div class="crh-search-modal-footer">
            <div class="crh-search-hints">
                <span class="crh-search-hint"><kbd>↵</kbd> Open</span>
                <span class="crh-search-hint"><kbd>↑↓</kbd> Navigate</span>
                <span class="crh-search-hint"><kbd>Esc</kbd> Close</span>
                <span class="crh-search-hint"><kbd>?</kbd> Shortcuts</span>
            </div>
        </div>
    </div>
</div>

## =====================================================
## KEYBOARD SHORTCUTS MODAL
## =====================================================
<div class="crh-kbd-modal" id="kbdModal" role="dialog" aria-modal="true" aria-labelledby="kbdModalTitle" style="display:none;">
    <div class="crh-kbd-backdrop" id="kbdBackdrop"></div>
    <div class="crh-kbd-dialog">
        <div class="crh-kbd-header">
            <h2 id="kbdModalTitle" class="crh-kbd-title">Keyboard Shortcuts</h2>
            <button class="crh-kbd-close" id="closeKbdModal" aria-label="Close shortcuts">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="crh-kbd-body">
            <div class="crh-kbd-group">
                <h3 class="crh-kbd-group-title">Navigation</h3>
                <ul class="crh-kbd-list">
                    <li class="crh-kbd-item"><span class="crh-kbd-desc">Open search</span><span class="crh-kbd-keys"><kbd>Ctrl</kbd><kbd>K</kbd></span></li>
                    <li class="crh-kbd-item"><span class="crh-kbd-desc">Previous page</span><span class="crh-kbd-keys"><kbd>←</kbd></span></li>
                    <li class="crh-kbd-item"><span class="crh-kbd-desc">Next page</span><span class="crh-kbd-keys"><kbd>→</kbd></span></li>
                    <li class="crh-kbd-item"><span class="crh-kbd-desc">Back to top</span><span class="crh-kbd-keys"><kbd>T</kbd></span></li>
                </ul>
            </div>
            <div class="crh-kbd-group">
                <h3 class="crh-kbd-group-title">Interface</h3>
                <ul class="crh-kbd-list">
                    <li class="crh-kbd-item"><span class="crh-kbd-desc">Toggle dark mode</span><span class="crh-kbd-keys"><kbd>D</kbd></span></li>
                    <li class="crh-kbd-item"><span class="crh-kbd-desc">Show shortcuts</span><span class="crh-kbd-keys"><kbd>?</kbd></span></li>
                    <li class="crh-kbd-item"><span class="crh-kbd-desc">Close / dismiss</span><span class="crh-kbd-keys"><kbd>Esc</kbd></span></li>
                </ul>
            </div>
        </div>
    </div>
</div>

## =====================================================
## HEADER — Two rows: Brand bar + Navigation strip
## =====================================================
<header class="crh-header">
    <div class="crh-header-bg"></div>
    <div class="crh-header-overlay"></div>

    ## ROW 1 — Brand bar
    <div class="crh-header-bar">
        <div class="crh-header-inner">
            <a href="$homeLink" class="crh-brand-link" aria-label="SKAO Creative Production Hub Home">
                <img src="${theme.baseUrl}/images/skao-logo-white.png" alt="SKAO Logo" class="crh-logo-img">
                <span class="crh-site-title">Creative Hub</span>
            </a>
            <div class="crh-header-actions">
                <button class="crh-theme-toggle" id="themeToggle" aria-label="Toggle dark mode" title="Toggle dark mode">
                    <svg class="crh-theme-icon-light" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                    <svg class="crh-theme-icon-dark" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="5"/>
                        <line x1="12" y1="1" x2="12" y2="3"/>
                        <line x1="12" y1="21" x2="12" y2="23"/>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                        <line x1="1" y1="12" x2="3" y2="12"/>
                        <line x1="21" y1="12" x2="23" y2="12"/>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                    </svg>
                </button>
                <button class="crh-mobile-search-btn" id="openSearchModalMobile" aria-label="Search" title="Search">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                </button>
                <button class="crh-mobile-menu-btn" id="mobileMenuBtn" aria-label="Open navigation menu" title="Open menu">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <line x1="4" y1="6" x2="20" y2="6"/>
                        <line x1="4" y1="12" x2="20" y2="12"/>
                        <line x1="4" y1="18" x2="20" y2="18"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    ## ROW 2 — Navigation strip
    ## Show first 6 child pages inline, overflow goes into "More" dropdown
    #set($rootChildren = $homePage.children)
    #set($maxVisible = 6)
    ## Pre-compute current section for nav active state
    #set($currentSection = false)
    #foreach($sec in $rootChildren)
        #if($page.title == $sec.title || ($page.parent && $page.parent.title == $sec.title) || ($page.parent && $page.parent.parent && $page.parent.parent.title == $sec.title) || ($page.parent && $page.parent.parent && $page.parent.parent.parent && $page.parent.parent.parent.title == $sec.title))
            #set($currentSection = $sec)
        #end
    #end
    <nav class="crh-nav-strip" id="headerNav" aria-label="Main navigation">
        <div class="crh-nav-strip-inner">
            <ul class="crh-nav-list">
                <li><a href="$homeLink" class="crh-nav-link #if($isHome)crh-nav-active#end">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    Home
                </a></li>
                #if($rootChildren && $rootChildren.size() > 0)
                    #set($navIndex = 0)
                    #foreach($navItem in $rootChildren)
                        #if($navIndex < $maxVisible)
                            <li><a href="$navItem.absoluteLink" class="crh-nav-link #if($page.title == $navItem.title || ($currentSection && $currentSection.title == $navItem.title))crh-nav-active#end" data-lastmod="$navItem.lastModificationDate">$navItem.title</a></li>
                        #end
                        #set($navIndex = $navIndex + 1)
                    #end
                    ## "More" dropdown if overflow exists
                    #if($rootChildren.size() > $maxVisible)
                        <li class="crh-nav-more" id="navMore">
                            <button class="crh-nav-more-btn" id="navMoreBtn" aria-expanded="false" aria-haspopup="true">
                                More
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>
                            <div class="crh-nav-more-dropdown" id="navMoreDropdown" role="menu">
                                #set($navIndex2 = 0)
                                #foreach($navItem in $rootChildren)
                                    #if($navIndex2 >= $maxVisible)
                                        <a href="$navItem.absoluteLink" class="crh-nav-link #if($page.title == $navItem.title || ($currentSection && $currentSection.title == $navItem.title))crh-nav-active#end" role="menuitem">$navItem.title</a>
                                    #end
                                    #set($navIndex2 = $navIndex2 + 1)
                                #end
                            </div>
                        </li>
                    #end
                #end
            </ul>
        </div>
    </nav>
</header>

## =====================================================
## 404 DETECTION — must come BEFORE homepage check.
## The "Not Found" page has no parent, so $homePage resolves
## to itself and $isHome would be true. Check title first.
## =====================================================
#set($pageTitle404 = $page.title.toLowerCase().trim())
#set($is404 = false)
#if($pageTitle404 == "not found" || $pageTitle404 == "page not found" || $pageTitle404 == "404")
    #set($is404 = true)
#end

#if($is404)
## =====================================================
## 404 ERROR PAGE — Interactive physics-based
## Matter.js loaded in <head> only for 404 pages
## =====================================================
    <div class="nf-container" id="notFoundContainer">
        <canvas class="nf-canvas" id="nfCanvas"></canvas>
        <div class="nf-content">
            <h1 class="nf-title">404</h1>
            <p class="nf-subtitle">Page Not Found</p>
            <p class="nf-text">The page you're looking for has drifted into the creative void.</p>
            <div class="nf-actions">
                <a href="$homeLink" class="nf-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    Return to Hub
                </a>
                <a href="https://jira.skatelescope.org/servicedesk/customer/portal/364" target="_blank" rel="noopener" class="nf-btn nf-btn-outline">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    Report an Issue
                </a>
            </div>
        </div>
    </div>

#elseif($isHome)
## =====================================================
## HOME PAGE CONTENT
## =====================================================

    ## ANNOUNCEMENT BANNER
    <div class="crh-announce-bar" id="announcementBanner">
        <div class="crh-announce-inner">
            <span class="crh-announce-text">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;margin-right:8px;vertical-align:middle;">
                    <path d="M12 2L15.09 8.26H22L17.55 12.5L19.64 18.76L12 14.5L4.36 18.76L6.45 12.5L2 8.26H8.91L12 2Z"/>
                </svg>
                New Brand Guidelines 2026 are now available — <a href="#" style="text-decoration:underline;color:inherit;">View updates</a>
            </span>
            <button class="crh-announce-close" id="announcementClose" aria-label="Dismiss announcement">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>
    </div>

    ## HERO SECTION — Two-column layout
    <section class="crh-hero">
        <div class="crh-hero-inner">
            <div class="crh-hero-grid">
                ## LEFT COLUMN
                <div class="crh-hero-left">
                    <h1 class="crh-hero-title">Creative Hub</h1>
                    <p class="crh-hero-subtitle">Your central resource for brand guidelines, templates, and creative assets</p>
                    <div class="crh-hero-search" id="heroSearchTrigger">
                        <svg class="crh-hero-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        </svg>
                        <span class="crh-hero-search-placeholder">Search templates, guidelines, assets...</span>
                        <kbd class="crh-hero-search-kbd">Ctrl+K</kbd>
                    </div>
                </div>

                ## RIGHT COLUMN — Support Card
                <div class="crh-hero-right">
                    <div class="crh-support-card">
                        <h3 class="crh-support-card-title">Need Creative Support?</h3>
                        <p class="crh-support-card-text">Submit a request to our creative team for custom design work and consultations</p>
                        <a href="https://jira.skatelescope.org/servicedesk/customer/portal/364" target="_blank" rel="noopener" class="crh-support-card-btn">Submit Creative Request →</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    ## Main Content Area
    <main id="main-content" class="crh-home-main">
        <div class="crh-home-inner">

            ## HOME PAGE BODY CONTENT
            ## Skipped on home — the homepage layout is fully defined by this template.
            ## Any Confluence page body content (macros, text) would appear as raw unstyled
            ## content and break the design. Edit the template to change homepage sections.

            ## BENTO ROW \u2014 Essentials (left) + Featured Templates (right)
            ## Essentials = pages labelled `essential` (compact stacked list)
            ## Featured Templates = pages labelled `featured-template` (media-object cards)
            <div class="crh-bento-row">
                <div class="crh-bento-col">
                    <section class="crh-home-section crh-popular-downloads">
                        <div class="crh-home-section-header">
                            <h2>
                                <svg class="crh-home-section-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15 8.5L22 9L17 14L18.5 21L12 17.5L5.5 21L7 14L2 9L9 8.5L12 2z"/></svg>
                                Essentials
                            </h2>
                        </div>
                        <div class="crh-popular-list" id="crhPopularList" data-space="$page.space.key" data-label="essential" data-limit="5">
                            <a class="crh-popular-item crh-popular-skeleton" href="#"><div class="crh-popular-icon"></div><div class="crh-popular-meta"><span class="crh-popular-title"></span><span class="crh-popular-detail"></span></div></a>
                            <a class="crh-popular-item crh-popular-skeleton" href="#"><div class="crh-popular-icon"></div><div class="crh-popular-meta"><span class="crh-popular-title"></span><span class="crh-popular-detail"></span></div></a>
                            <a class="crh-popular-item crh-popular-skeleton" href="#"><div class="crh-popular-icon"></div><div class="crh-popular-meta"><span class="crh-popular-title"></span><span class="crh-popular-detail"></span></div></a>
                        </div>
                    </section>
                </div>
                <div class="crh-bento-col">
                    <section class="crh-home-section crh-featured-templates">
                        <div class="crh-home-section-header">
                            <h2>
                                <svg class="crh-home-section-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                                Featured Templates
                            </h2>
                            #set($templatesLink = $homeLink)
                            #foreach($tp in $homePage.children)
                                #if($tp.title.toLowerCase().contains("template"))
                                    #set($templatesLink = $tp.absoluteLink)
                                #end
                            #end
                            <a href="$templatesLink" class="crh-home-section-link">Browse all &rarr;</a>
                        </div>
                        <div class="crh-template-grid" id="crhTemplateGrid" data-space="$page.space.key" data-label="featured-template" data-limit="3">
                            <article class="crh-template-card crh-template-skeleton"><div class="crh-template-thumb"></div><div class="crh-template-body"><span class="crh-template-title"></span><span class="crh-template-desc"></span></div></article>
                            <article class="crh-template-card crh-template-skeleton"><div class="crh-template-thumb"></div><div class="crh-template-body"><span class="crh-template-title"></span><span class="crh-template-desc"></span></div></article>
                            <article class="crh-template-card crh-template-skeleton"><div class="crh-template-thumb"></div><div class="crh-template-body"><span class="crh-template-title"></span><span class="crh-template-desc"></span></div></article>
                        </div>
                    </section>
                </div>
            </div>

            ## WHAT'S NEW \u2014 tabbed activity panel.
            ## Two tabs: All updates (any page in space) / Guidelines only (pages labelled brand-guideline).
            ## Replaces the old Recent Updates card grid and Recently Updated Guidelines list.
            #set($brandLink = $homeLink)
            #foreach($bg in $homePage.children)
                #if($bg.title.toLowerCase().contains("brand"))
                    #set($brandLink = $bg.absoluteLink)
                #end
            #end
            #set($whatsNewLink = $homeLink)
            #foreach($wn in $homePage.children)
                #if($wn.title.toLowerCase().contains("what"))
                    #set($whatsNewLink = $wn.absoluteLink)
                #end
            #end
            <section class="crh-home-section crh-activity-panel" id="crhActivity"
                     data-space="$page.space.key"
                     data-home-title="$homePage.title"
                     data-all-link="$whatsNewLink"
                     data-guidelines-link="$brandLink">
                <div class="crh-activity-header">
                    <h2>
                        <svg class="crh-home-section-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        What&rsquo;s New
                    </h2>
